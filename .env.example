# ── Product ───────────────────────────────────────────────────────────────────
# Which product config to load from products/{PRODUCT}.json
# Built-in: erp, fintech, fintech_docs  — add your own in products/
PRODUCT=erp

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
LLM_MODEL=phi3:mini
EMBED_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_PATH=./db
# COLLECTION_NAME is a fallback; each product config sets its own collection name

# ── RAG / performance ─────────────────────────────────────────────────────────
N_RESULTS=3        # documents retrieved per query   (lower = faster)
EXCERPT_LEN=250    # chars of each doc shown to LLM  (lower = faster)
HISTORY_MSGS=6     # last N messages kept in context
NUM_PREDICT=512    # max tokens the LLM can generate
MIN_RELEVANCE=0.35 # minimum similarity to use a doc (0–1, higher = stricter)

# ── Webhook auth ──────────────────────────────────────────────────────────────
# Leave empty to disable auth (dev/internal). Set a secret for production.
WEBHOOK_SECRET=

# ── Admin panel auth ───────────────────────────────────────────────────────────
# Password required to access /admin and all /api/admin/* endpoints.
# Leave empty to disable auth (dev only — always set in production).
ADMIN_PASSWORD=

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
SESSIONS_DB=./sessions.db    # SQLite database for conversation history
DATA_DIR=./data              # directory for bulk import files
